UiDeviceItem:disabled {background:#aaaaaa;}

UiDeviceItem QLabel#DeviceName {font:normal 12px; color:#444;}
UiDeviceItem QLabel#DeviceName:disabled {color:#888888;}

UiDeviceItem QLabel#Tags {font:normal 11px; color:#FF9900; background:#fff; border-radius:3px; padding:0px 2px 0px 2px; border:0px solid #ddd;}
UiDeviceItem QLabel#Tags[active=true] {background:#fff;}
UiDeviceItem QLabel#Tags:disabled {background:#dddddd; color:#888888;}

UiDeviceItem QLabel#Tips {font: normal 11px; color:#888888;}
