/* ------------------ UiTabWidget & UiTabBar ---------------- */
UiTabWidget {background: transparent;}
UiTabWidget QFrame#Body {background: #ffffff; border-radius: 0px; font-size: 12px; border:none;}

UiTabBar {background:#f3f3f3; border-bottom:0px solid #aaa; padding:0px 0px -8px 0px;}
UiTabBar QScrollBar:horizontal {padding-top:1px;}
UiTabBar QScrollBar:horizontal:hover {padding-top:1px;}
UiTabBar QScrollBar::handle:horizontal {background:#22000000;}
UiTabBar QScrollBar::handle:horizontal:hover {background:#44000000;}
UiTabBar QScrollBar::handle:horizontal:pressed {background:#88000000;}

UiTab {border:none; font:normal 13px; padding: 3px 20px 3px 14px; border-right:1px solid qlineargradient(x1:0, y1:0, x2:0, y2:1, stop:0 #f3f3f3 ,stop:1 #f3f3f3); text-align:center;}
/*UiTab[selected=true] {background:#ffffff; color:#000000; padding: 3px 20px 0px 20px; border-bottom:1px solid #eee;}*/
UiTab[selected=true] {background:#ffffff; color:#333; border-bottom:0px solid #3485D6;}
UiTab[selected=false] {background:#ececec; color:#b3333333; border-bottom:0px solid #aaa;}
UiTab[closeable=true] {padding-right: 28px;}
UiTab:hover[selected=false] {background:#f6f6f6; color:#333;}

UiTab UiFontIconButton#CloseBtn{background:transparent; padding:0px 0px 2px 0px; margin:0px 0px 0px 0px; font-size:8px; color:#999999;}
UiTab UiFontIconButton#CloseBtn:hover {background:#FF334E; border-radius: 2px; color:#eeeeee;}
UiTab UiFontIconButton#CloseBtn:pressed {background:#F02F49; border-radius: 2px; color:#eeeeee;}

