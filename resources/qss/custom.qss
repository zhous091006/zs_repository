UiCustomMainWindow {color:red; min-width:100px; min-height:20px;}
UiCustomMainWindow QFrame#ContainerWidget {background:#f3f3f3;}
UiCustomMainWindow QFrame#CentralWidget {border:2px solid #3388ff; background:red;}


UiCustomMainWindowTopBar {background:#dddddd; border:none; margin:0px 0px 0px 0px; padding:0px 0px 0px 30px; font-size:13px; border-bottom:0px solid #666;}
UiCustomMainWindowTopBar::item{border:none; color:#333333; margin:0px 0px 0px 0px; padding:5px 9px 5px 9px; min-height:24px;}
UiCustomMainWindowTopBar::item:selected{background:rgba(0,0,0,20); border-radius:0px;}
UiCustomMainWindowTopBar::item:disabled{color:#555555;}

UiCustomMainWindowTopBar QLabel#AppLogo{background:transparent;}
UiCustomMainWindowTopBar QLabel#Version{font-size: 11px; color:#222222;}



UiMenu {color:#222222; font-size:13px; background:#fff; border:0px solid #ddd; padding:6px 4px 0px 6px; margin:1px 4px 4px 0px; border-radius:0px;}

