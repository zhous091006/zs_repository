/* ------------------ UiTaskToolBar ---------------- */
UiTaskToolBar {background:#fff; border-bottom:1px solid #e0e0e0; padding:0px 8px 0px 8px;}

UiTaskToolBar QFrame#SplitLine {background: #dddddd;}

UiTaskToolBar UiPushButton#Icon {font-family:"Arial"; color:rgba(0,0,0,140); background:transparent; border:none; font-size: 12px; padding:0px 0px 2px 0px;}
UiTaskToolBar UiPushButton#Locate {font-family:"Arial"; color:rgba(0,0,0,140); background:transparent; border:none; font-size: 18px; padding:-2px 0px 2px 0px;}
UiTaskToolBar UiPushButton#Reload {font-family:"Arial"; color:rgba(0,0,0,140); background:transparent; border:none; font-size: 14px; padding:0px 0px 2px 0px;}
UiTaskToolBar UiPushButton#Icon:hover,
UiTaskToolBar UiPushButton#Locate:hover,
UiTaskToolBar UiPushButton#Reload:hover {background:rgba(0,0,0,30); border-radius:2px;}
UiTaskToolBar UiPushButton#Icon:pressed,
UiTaskToolBar UiPushButton#Locate:pressed,
UiTaskToolBar UiPushButton#Reload:pressed{background:rgba(0,0,0,40); border-radius:2px;}
UiTaskToolBar UiPushButton#Icon:disabled,
UiTaskToolBar UiPushButton#Locate:disabled,
UiTaskToolBar UiPushButton#Reload:disabled {color:rgba(0,0,0,80); background:transparent;}

UiTaskToolBar UiFontIconButton#Folder {color:#DE7E22; font-size:10px;}
UiTaskToolBar UiFontIconButton#Folder:disabled {color:rgba(0,0,0,80);}

UiTaskToolBar UiFontIconButton#Start {color:#499C54; font-size:10px;}
UiTaskToolBar UiFontIconButton#Start:disabled {color:rgba(0,0,0,80);}
UiTaskToolBar UiFontIconButton#Stop {color:#E4605C; font-size:10px;}
UiTaskToolBar UiFontIconButton#Stop:disabled {color:rgba(0,0,0,80);}

