UiAutoUploadPage UiMenu {font-size:12px; border:1px solid #ccc;}



QFrame#SplitLine {background: #f5f5f5; margin-left:4px; margin-right:4px;}

UiSplitLine {background:#f0f0f0;}


/*-----------------------------------------------------------------------------------------------*/
UiPushButton {background:#007acc; border-radius:0px; font-size:13px; color:#ffffff; padding:3px 4px 4px 4px; border:0px solid #197DDF;}
UiPushButton:focus {background:#1983E6;}
UiPushButton:hover {background:#0071BB; color:#f0f0f0;}
UiPushButton:pressed {background: #1878D6;}
UiPushButton:disabled {background: #e4e4e4; color:#aaaaaa;}
UiPushButton::menu-indicator{image:none; width:0px;}

UiPushButton#Icon {border-radius:2px; padding:0px 0px 0px 0px; margin:0px;}
UiPushButton#Icon {font-family:"Arial"; color:rgba(0,0,0,140); background:transparent; border:none; font-size:16px;}
UiPushButton#Icon:hover {background:rgba(0,0,0,30); border-radius:2px;}
UiPushButton#Icon:pressed {background:rgba(0,0,0,40); border-radius:2px;}
UiPushButton#Icon:disabled {color:rgba(0,0,0,80); background:transparent;}

UiFontIconButton {
    color:rgba(0,0,0,140); background:transparent; border:none;
    font-family:"fontello"; font-size:10px; padding:0px 0px 0px 0px; margin:0px;
}
UiFontIconButton:hover {background:rgba(0,0,0,30); border-radius:2px;}
UiFontIconButton:pressed {background:rgba(0,0,0,40); border-radius:2px;}
UiFontIconButton:disabled {color:rgba(0,0,0,80); background:transparent;}


/*-----------------------------------------UiDialogBase------------------------------------------------*/
UiDialogBase QFrame#CentralWidget {background:#F2F2F2; color:white; border:0px solid #888888; border-radius:0px;}
UiDialogBase QFrame#CentralWidget[alert=true] {border:0px solid #777777;}
UiDialogBase QFrame#CentralWidget[alert=false] {border:0px solid #aaaaaa;}
UiDialogBase QFrame#BodyWidget {background:#ffffff; margin:0px; border-bottom-left-radius:0px; border-bottom-right-radius:0px;}

UiDialogBase UiDialogTitleBar {background:#666; color:#000000; border-top-left-radius:0px; border-top-right-radius:0px;}
UiDialogBase UiDialogTitleBar[alert=true] {background:#f4f4f4;}
UiDialogBase UiDialogTitleBar[alert=false] {background:#fefefe;}
UiDialogBase UiDialogTitleBar QLabel#TitleName {background:transparent; color:#e6444444; font-size:12px;}


UiDialogBase QScrollArea QFrame#Container{background: transparent;}


/*----------------------------------------- UiMessageBox ------------------------------------------------*/
UiMessageBox QFrame#ButtonArea {background:#f8f8f8;}

UiMessageBox QLabel#Icon[level="warning"] {image: url('resources/images/widget/message_box/warning_32.svg');}
UiMessageBox QLabel#Icon[level="information"] {image: url('resources/images/widget/message_box/info_32.svg');}
UiMessageBox QLabel#Icon[level="tip"] {image: url('resources/images/widget/message_box/info_32.svg');}
UiMessageBox QLabel#Icon[level="question"] {image: url('resources/images/widget/message_box/question_96.png');}
UiMessageBox QLabel#Icon[level="error"] {image: url('resources/images/widget/message_box/error_32.svg');}

UiMessageBox UiPushButton {background:#aaaaaa; border:0px solid #e4e4e4; border-radius:0px; color:#000000;}
UiMessageBox UiPushButton:hover {border:1px solid #000000; background:#aaaaaa; color:#000000;}
UiMessageBox UiPushButton:focus {background:#1983E6; color:white;}
UiMessageBox UiPushButton:pressed {background: #1878D6; border:1px solid #000000;}
UiMessageBox UiPushButton:disabled {background: #cccccc; color:#888888;}



